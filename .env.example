# Local environment for `vercel dev` (shared-assumptions API).
# Run `vercel pull --environment=development` to populate a real .env.local,
# or copy this file to .env.local and fill in values from the Upstash/Vercel
# dashboard. .env.local is gitignored — never commit real values.

# Dedicated shared-assumptions Redis (preferred; both must be set as a pair).
# Mind the spelling: a historical typo (HARED_...) silently fell back to the
# KV_ variables below.
SHARED_ASSUMPTIONS_REDIS_REST_URL=
SHARED_ASSUMPTIONS_REDIS_REST_TOKEN=

# Fallback: Vercel KV / Upstash integration variables (set by `vercel pull`).
KV_REST_API_URL=
KV_REST_API_TOKEN=
