set -e

# Keep .agents/skills a byte-for-byte mirror of the canonical .claude/skills.
# Act when either skill tree is staged, and refuse mismatched .agents edits
# instead of overwriting them.
if ! git diff --cached --quiet -- .claude/skills .agents/skills; then
  # The checks below read from the WORKING TREE, so unstaged skill edits would make
  # the committed mirror differ from what we validate. Refuse loudly.
  untracked_skill_files=$(git ls-files --others --exclude-standard -- .claude/skills .agents/skills)
  if ! git diff --quiet -- .claude/skills .agents/skills || [ -n "$untracked_skill_files" ]; then
    echo "pre-commit: skill files have unstaged changes while skill edits are staged." >&2
    echo "Stage all skill edits (git add .claude/skills .agents/skills) or stash the rest, then re-commit." >&2
    if [ -n "$untracked_skill_files" ]; then
      echo "Untracked skill files:" >&2
      echo "$untracked_skill_files" | sed 's/^/  /' >&2
    fi
    exit 1
  fi

  if ! git diff --cached --quiet -- .agents/skills; then
    node scripts/sync-skills.js --check || {
      echo "pre-commit: .agents/skills edits must match .claude/skills exactly." >&2
      echo "Move skill changes into .claude/skills, run npm run sync-skills, and stage both trees." >&2
      exit 1
    }
  elif ! git diff --cached --quiet -- .claude/skills; then
    node scripts/sync-skills.js
    git add .agents/skills
    node scripts/sync-skills.js --check
  fi
fi

npx lint-staged
